# ============================================
# JAYBHADRA BUILDERS — ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env.local and fill in values
# NEVER commit .env.local to git

# --- Firebase Configuration ---
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# --- Business Contact ---
NEXT_PUBLIC_ADMIN_WHATSAPP=919876543210   # with country code, no +
NEXT_PUBLIC_ADMIN_PHONE=+919876543210
NEXT_PUBLIC_ADMIN_EMAIL=info@jayabhadrabuilders.com

# --- EmailJS (for email notifications) ---
NEXT_PUBLIC_EMAILJS_SERVICE_ID=your_emailjs_service_id
NEXT_PUBLIC_EMAILJS_ADMIN_TEMPLATE_ID=template_admin_lead
NEXT_PUBLIC_EMAILJS_USER_TEMPLATE_ID=template_user_confirm
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_emailjs_public_key

# --- Optional: Calendly ---
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/jaybhadrabuilders
